# ---- LocalSend receiver -----------------------------------------------------
# Display name shown to senders in the LocalSend app.
LOCALSEND_ALIAS=Paperless Inbox
# Optional PIN. Leave empty to accept every transfer without prompting.
LOCALSEND_PIN=

# ---- Filesystem -------------------------------------------------------------
INCOMING_DIR=/data/incoming
RETRY_DIR=/data/retry
# Seconds to wait after the last byte before forwarding.
WATCHER_DEBOUNCE_SECONDS=2

# ---- Paperless-ngx (required) ----------------------------------------------
PAPERLESS_URL=https://paperless.example.lan
PAPERLESS_TOKEN=changeme
# Set to false if your Paperless instance uses a self-signed certificate.
PAPERLESS_VERIFY_SSL=true

# ---- Paperless defaults (optional) -----------------------------------------
# Comma-separated tag IDs to assign to every uploaded document.
PAPERLESS_DEFAULT_TAGS=
PAPERLESS_DEFAULT_CORRESPONDENT=
PAPERLESS_DEFAULT_DOCUMENT_TYPE=
PAPERLESS_DEFAULT_STORAGE_PATH=
# Prepended to the document title (derived from filename stem).
PAPERLESS_TITLE_PREFIX=

# ---- Behaviour --------------------------------------------------------------
# Poll /api/tasks/ to confirm consumption succeeded before deleting locally.
PAPERLESS_POLL_TASK=true
PAPERLESS_POLL_TIMEOUT_SECONDS=60
PAPERLESS_POLL_INTERVAL_SECONDS=2
# Periodic rescan of RETRY_DIR.
RETRY_INTERVAL_SECONDS=300

# ---- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
